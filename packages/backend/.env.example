# ============================================
# CatSwap Backend Environment Configuration
# ============================================

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=catswap
DATABASE_PASSWORD=catswap
DATABASE_NAME=catswap
DATABASE_SSL=false
DATABASE_LOGGING=false

# Redis Configuration (for BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Blockchain Configuration
BLOCKCHAIN_NETWORK=testnet
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_RPC_USER=
BLOCKCHAIN_RPC_PASSWORD=

# Swap Configuration
SWAP_MIN_AMOUNT=0.0001
SWAP_MAX_AMOUNT=100
SWAP_DEFAULT_SLIPPAGE=0.5

# Fee Configuration (in basis points, 1 = 0.01%)
FEE_SWAP=30
FEE_PROTOCOL=5

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Logging
LOG_LEVEL=debug
